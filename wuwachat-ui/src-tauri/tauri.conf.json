{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "wuwachat-ui",
  "version": "0.1.0",
  "identifier": "com.kis.wuwachat-ui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "wuwachat-ui",
        "width": 1180,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "label": "main",
        "resizable": false,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default",
        "shell"
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "externalBin": [
      "bin/wuwachat-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}